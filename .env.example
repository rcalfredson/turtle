# Optional API key fallback for Alpha Vantage
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# Default simulation parameters
STARTING_CAPITAL=100000
RISK_PERCENT=1

# Enable request-time diagnostics for historical data fetches
DEBUG_MARKET_DATA=false

# Yahoo historical data cache
MARKET_DATA_CACHE=true
MARKET_DATA_CACHE_DIR=.cache/market-data
MARKET_DATA_CACHE_TTL_HOURS=24
