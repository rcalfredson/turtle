doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title Turtle Trading Simulator
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet" href="/css/style.css")
  body
    header
      h1 Turtle Trading Simulator
      h2 Build and test a vanilla turtle strategy with historical end-of-day data.
    main
      section.card
        h2 Choose a ticker and timeframe
        form#simulationForm
          .field-group
            label(for="tickerInput") Search ticker symbol
            input#tickerInput(type="text" placeholder="Start typing a company or symbol")
            input#selectedSymbol(type="hidden" name="symbol")
            ul.symbol-list#symbolResults
          .grid-2
            div
              label(for="fromDate") From
              input#fromDate(type="date" name="from")
            div
              label(for="toDate") To
              input#toDate(type="date" name="to")
          .grid-2
            div
              label(for="capital") Starting capital
              input#capital(type="number" name="capital" value="100000" min="1000" step="1000")
            div
              label(for="riskPercent") Risk per trade (%)
              input#riskPercent(type="number" name="riskPercent" value="1" min="0.1" step="0.1")
          button#runSimulation(type="submit") Run simulation
      section.card
        h2 Simulation results
        div#simulationResults
    script(src="/js/app.js")
